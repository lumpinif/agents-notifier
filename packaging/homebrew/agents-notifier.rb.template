class AgentsNotifier < Formula
  desc "Local-only notifications for AI coding agents"
  homepage "https://github.com/lumpinif/agents-notifier"
  version "0.1.4"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/lumpinif/agents-notifier/releases/download/v#{version}/agents-notifier-aarch64-apple-darwin.tar.gz"
      sha256 "REPLACE_WITH_AARCH64_SHA256"
    else
      url "https://github.com/lumpinif/agents-notifier/releases/download/v#{version}/agents-notifier-x86_64-apple-darwin.tar.gz"
      sha256 "REPLACE_WITH_X86_64_SHA256"
    end
  end

  def install
    bin.install "agents-notifier"
  end

  test do
    assert_match "agents-notifier", shell_output("#{bin}/agents-notifier --help")
  end
end
